# === পূরণ করার আগে অবশ্যই নতুন Bot Token এবং DB পাসওয়ার্ড জেনারেট করে নাও ===
# পুরনোটা এই চ্যাটে একবার লেখা হয়ে গেছে, তাই সেটা আর নিরাপদ না।

# BotFather থেকে /revoke করে নতুন টোকেন নাও
BOT_TOKEN=your_new_bot_token_here

# MongoDB Atlas এ গিয়ে ডাটাবেজ ইউজারের পাসওয়ার্ড রিসেট করে নতুনটা বসাও
MONGODB_URI=mongodb+srv://<username>:<new_password>@cluster0.yjot2y9.mongodb.net/dramahouse?appName=Cluster0

# তোমার Telegram User ID (এটা secret না, এটা রাখা যাবে)
ADMIN_TELEGRAM_ID=6522135005

# Admin panel এ লগইন করার জন্য একটা শক্ত পাসওয়ার্ড বানাও (bot token/DB password থেকে আলাদা)
ADMIN_PANEL_PASSWORD=set_a_strong_password_here

# Admin panel session সাইন করার জন্য random string (কমান্ড: openssl rand -hex 32)
SESSION_SECRET=generate_a_random_string_here

# Adsgram থেকে পাওয়া Block ID
ADSGRAM_BLOCK_ID=your_adsgram_block_id

# Cloudinary (thumbnail/broadcast image রাখার জন্য — cloudinary.com এ ফ্রি অ্যাকাউন্ট বানাও)
# Dashboard এ "API Environment variable" নামে ঠিক এই ফরম্যাটেই একটা string দেওয়া থাকে, সেটাই কপি করো
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# তোমার bot username (@ ছাড়া), mini app deep link বানাতে লাগবে
BOT_USERNAME=your_bot_username

# Server যেখানে হোস্ট হবে তার পাবলিক URL (Mini App এবং webhook এর জন্য)
PUBLIC_URL=https://yourdomain.example.com

# Telegram channel button link (নিচের ডান পাশের বাটন)
TELEGRAM_CHANNEL_LINK=https://t.me/+nQBEmrjwdKQ1YTA9

PORT=3000
